# All optional — the app works with no .env at all (free CARTO dark basemap, no key).

# Approximate map center as "lng,lat" (default: Miami)
# VITE_MAP_CENTER=-80.1918,25.7617

# Override the basemap entirely with any MapLibre style URL
# VITE_MAP_STYLE=https://basemaps.cartocdn.com/gl/dark-matter-gl-style/style.json

# Use Mapbox dark-v11 instead of CARTO (requires a token)
# VITE_MAPBOX_TOKEN=pk.your_token_here
